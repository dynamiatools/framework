<project xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd"
         xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>tools.dynamia.modules</groupId>
        <artifactId>tools.dynamia.modules.saas.parent</artifactId>
        <version>26.6.0</version>
    </parent>

    <name>DynamiaModules - SaaS Tenant Mobility (Migration)</name>
    <artifactId>tools.dynamia.modules.saas.migration</artifactId>
    <url>https://www.dynamia.tools/modules/saas/migration</url>
    <description>
        Tenant Mobility module for DynamiaTools SaaS. Provides async export, import, clone,
        backup and restore of tenant data via streaming JSON with JPA-based entity discovery.
    </description>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${maven.compiler}</version>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <encoding>${source.encoding}</encoding>
                    <parameters>true</parameters>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <dependencies>

        <!-- SaaS core: Account entity, AccountService, AccountServiceAPI -->
        <dependency>
            <groupId>tools.dynamia.modules</groupId>
            <artifactId>tools.dynamia.modules.saas</artifactId>
            <version>26.6.0</version>
        </dependency>

        <!-- SaaS API: AccountAware, AccountExportIgnore annotations -->
        <dependency>
            <groupId>tools.dynamia.modules</groupId>
            <artifactId>tools.dynamia.modules.saas.api</artifactId>
            <version>26.6.0</version>
        </dependency>

        <!-- SaaS JPA: SimpleEntitySaaS base classes -->
        <dependency>
            <groupId>tools.dynamia.modules</groupId>
            <artifactId>tools.dynamia.modules.saas.jpa</artifactId>
            <version>26.6.0</version>
        </dependency>

        <!-- Dynamia Integration: SchedulerUtil, VT, Containers -->
        <dependency>
            <groupId>tools.dynamia</groupId>
            <artifactId>tools.dynamia.integration</artifactId>
            <version>26.6.0</version>
        </dependency>

        <!-- Dynamia Domain JPA: CrudService, SimpleEntity, JpaUtils -->
        <dependency>
            <groupId>tools.dynamia</groupId>
            <artifactId>tools.dynamia.domain.jpa</artifactId>
            <version>26.6.0</version>
        </dependency>

        <!-- Hibernate ORM: EntityManagerFactory, Metamodel -->
        <dependency>
            <groupId>org.hibernate.orm</groupId>
            <artifactId>hibernate-core</artifactId>
        </dependency>

        <!-- Spring Boot autoconfigure: @ConfigurationProperties, @ConditionalOn* -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-autoconfigure</artifactId>
        </dependency>

        <!-- Jackson Databind: ObjectMapper, JsonGenerator, JsonParser -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
        </dependency>

        <!-- Jackson JavaTime module: LocalDate, LocalDateTime serialization -->
        <dependency>
            <groupId>com.fasterxml.jackson.datatype</groupId>
            <artifactId>jackson-datatype-jsr310</artifactId>
        </dependency>

        <!-- Jakarta APIs (provided by container) -->
        <dependency>
            <groupId>jakarta.servlet</groupId>
            <artifactId>jakarta.servlet-api</artifactId>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>jakarta.annotation</groupId>
            <artifactId>jakarta.annotation-api</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Test -->
        <dependency>
            <groupId>junit</groupId>
            <artifactId>junit</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <version>5.20.0</version>
            <scope>test</scope>
        </dependency>

    </dependencies>

</project>

